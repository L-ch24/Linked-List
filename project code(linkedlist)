class Node:
    def __init__(self, data):
        self.data = data
        self.next = None


class linkedlist:
    def __init__(self):
        self.head = None

    # 삽입 함수 (index 생략 가능)
    def insert(self, data, index=None):
        new_node = Node(data)

        # 1. 리스트가 비어있거나, 맨 앞 삽입
        if self.head is None or index == 0:
            new_node.next = self.head
            self.head = new_node
            return

        current = self.head
        prev = None
        count = 0

        # 2. 중간 또는 끝 삽입
        while current is not None and (index is None or count < index):
            prev = current
            current = current.next
            count += 1

        prev.next = new_node
        new_node.next = current

    # 삭제 함수 (값 기준)
    def delete(self, data):
        current = self.head
        prev = None

        # 1. 헤드 삭제
        if current is not None and current.data == data:
            self.head = current.next
            return

        # 2. 중간/끝 삭제
        while current is not None:
            if current.data == data:
                prev.next = current.next
                return
            prev = current
            current = current.next

        print("삭제할 값이 리스트에 없습니다.")

    # 출력 함수
    def display(self):
        current = self.head
        while current:
            print(current.data, end=" -> ")
            current = current.next
        print("None")

 # 연결 리스트 생성
music_list = linkedlist()

# 삽입
music_list.insert("Shape of You")     # 첫 번째
music_list.insert("Dynamite")         # 마지막
music_list.insert("Attention", 1)     # 중간 삽입
music_list.insert("Hype Boy", 0)      # 맨 앞

print("초기 리스트:")
music_list.display()

# 삭제
music_list.delete("Dynamite")
print("\n'Dynamite' 삭제 후:")
music_list.display()

music_list.delete("Hype Boy")
print("\n'Hype Boy' 삭제 후:")
music_list.display()
